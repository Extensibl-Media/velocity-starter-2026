# =============================================================================
# Velocity Web Studios Starter - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
SITE_URL=https://example.com

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# PUBLIC_GTM_ID=GTM-XXXXXXX

# -----------------------------------------------------------------------------
# Search Engine Verification (optional)
# -----------------------------------------------------------------------------
# GOOGLE_SITE_VERIFICATION=your-verification-code
# BING_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------------------------------------
# Maps (optional)
# -----------------------------------------------------------------------------
# PUBLIC_GOOGLE_MAPS_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# GoHighLevel (optional)
# -----------------------------------------------------------------------------
# PUBLIC_GHL_CHAT_WIDGET_ID=your-widget-id
# PUBLIC_GHL_LOCATION_ID=your-location-id