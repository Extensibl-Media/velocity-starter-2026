---
import { getBusinessData } from '@/lib/utils';

interface Props {
  theme?: 'default' | 'alt' | 'muted' | 'inverse' | 'primary' | 'accent';
  data?: Record<string, unknown>;
}

const { theme = 'default', data } = Astro.props;

const business = await getBusinessData();

const foundingYear = (data?.foundingYear as number) ?? null;
const yearsInBusiness = foundingYear ? new Date().getFullYear() - foundingYear : null;

const googleRating = (data?.googleRating as number) ?? null;
const reviewCount = (data?.reviewCount as number) ?? null;
const showFamilyOwned = (data?.familyOwned as boolean) ?? true;
const showLicensedInsured = (data?.licensedInsured as boolean) ?? true;

const fullStars = googleRating ? Math.floor(googleRating) : 0;
const hasHalf = googleRating ? googleRating % 1 >= 0.5 : false;
const emptyStars = googleRating ? 5 - fullStars - (hasHalf ? 1 : 0) : 0;

const badges = [
  yearsInBusiness && { id: 'years', label: `${yearsInBusiness}+ Years in Business` },
  googleRating && {
    id: 'rating',
    label: googleRating.toFixed(1),
    sublabel: reviewCount ? `${reviewCount.toLocaleString()} Google Reviews` : 'Google Reviews',
  },
  showLicensedInsured && { id: 'licensed', label: 'Licensed & Insured' },
  showFamilyOwned && { id: 'family', label: 'Family Owned & Operated' },
].filter(Boolean) as Array<{ id: string; label: string; sublabel?: string }>;
---

<section class={`section-wrapper section-py-xs theme-${theme}`}>
  <div class="section-container">
    <ul class="flex flex-wrap items-center justify-center gap-y-6 gap-x-8 md:gap-x-12 list-none m-0 p-0">
      {badges.map((badge, i) => (
        <li class="flex items-center gap-x-8 md:gap-x-12">
          <div class="flex items-center gap-3">

            {badge.id === 'years' && (
              <>
                <span
                  class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full"
                  style="background-color: var(--theme-border);"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" style="color: var(--theme-fg);" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </span>
                <span class="text-sm font-semibold theme-text leading-tight">{badge.label}</span>
              </>
            )}

            {badge.id === 'rating' && (
              <>
                <span
                  class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full"
                  style="background-color: var(--theme-border);"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                </span>
                <div class="leading-tight">
                  <div class="flex items-center gap-1.5">
                    <span class="text-sm font-bold theme-text">{badge.label}</span>
                    <span
                      class="flex items-center gap-0.5"
                      aria-label={`${badge.label} out of 5 stars`}
                    >
                      {Array.from({ length: fullStars }).map(() => (
                        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="#FBBF24" aria-hidden="true">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                      {hasHalf && (
                        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" aria-hidden="true">
                          <defs>
                            <linearGradient id="half-star-grad">
                              <stop offset="50%" stop-color="#FBBF24"/>
                              <stop offset="50%" stop-color="#D1D5DB"/>
                            </linearGradient>
                          </defs>
                          <path fill="url(#half-star-grad)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      )}
                      {Array.from({ length: emptyStars }).map(() => (
                        <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="#D1D5DB" aria-hidden="true">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                    </span>
                  </div>
                  <span class="text-xs theme-text-muted">{badge.sublabel}</span>
                </div>
              </>
            )}

            {badge.id === 'licensed' && (
              <>
                <span
                  class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full"
                  style="background-color: var(--theme-border);"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" style="color: var(--theme-fg);" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </span>
                <span class="text-sm font-semibold theme-text leading-tight">{badge.label}</span>
              </>
            )}

            {badge.id === 'family' && (
              <>
                <span
                  class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full"
                  style="background-color: var(--theme-border);"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" style="color: var(--theme-fg);" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                  </svg>
                </span>
                <span class="text-sm font-semibold theme-text leading-tight">{badge.label}</span>
              </>
            )}

          </div>

          {i < badges.length - 1 && (
            <span
              class="hidden md:block h-8 w-px shrink-0"
              style="background-color: var(--theme-border);"
              aria-hidden="true"
            />
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
