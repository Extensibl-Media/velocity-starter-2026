---
import type { NavNode } from "@/lib/utils";

interface Props {
  node: NavNode;
  depth?: number;
}

const { node, depth = 0 } = Astro.props;
const hasChildren = node.children && node.children.length > 0;
const dropdownId = `dropdown-${node.label.toLowerCase().replace(/\s+/g, '-')}`;
---

{depth === 0 && hasChildren ? (
  <li class="relative group" data-dropdown>
    {node.href ? (
      <a href={node.href} class="nav-link flex items-center gap-1">
        {node.label}
        <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </a>
    ) : (
      <button
        class="nav-link flex items-center gap-1"
        aria-haspopup="menu"
        aria-expanded="false"
        aria-controls={dropdownId}
        data-dropdown-trigger
      >
        {node.label}
        <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
    )}
    <ul
      id={dropdownId}
      class="dropdown-menu absolute top-full left-0 mt-1 min-w-48 bg-bg border border-border rounded-lg shadow-lg py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
      role="menu"
    >
      {node.children?.map((child) => (
        <Astro.self node={child} depth={1} />
      ))}
    </ul>
  </li>
) : depth === 1 && hasChildren ? (
  <li class="relative group/nested" data-dropdown-nested>
    <button class="dropdown-item flex items-center justify-between w-full gap-4" data-nested-trigger>
      {node.label}
      <svg class="w-3 h-3 transition-transform duration-200 group-hover/nested:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <polyline points="9 6 15 12 9 18" />
      </svg>
    </button>
    <ul class="nested-menu absolute top-0 left-full min-w-48 bg-bg border border-border rounded-lg shadow-lg py-1 opacity-0 invisible group-hover/nested:opacity-100 group-hover/nested:visible transition-all duration-200 z-50">
      {node.children?.map((child) => (
        <Astro.self node={child} depth={2} />
      ))}
    </ul>
  </li>
) : depth === 1 ? (
  <li role="menuitem">
    <a href={node.href} class="dropdown-item">
      {node.label}
    </a>
  </li>
) : (
  <li role="menuitem">
    <a href={node.href} class="dropdown-item">
      {node.label}
    </a>
  </li>
)}