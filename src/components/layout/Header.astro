---
import { getBusinessData } from "@/lib/utils";
import NavItem from "@/components/layout/NavItem.astro";
import type { NavNode } from "@/lib/utils";

interface Props {
  navItems: NavNode[];
}

const { navItems } = Astro.props;
const business = await getBusinessData();
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-bg border-b border-border transition-shadow duration-300"
  data-header
>
  <!-- Top bar -->
  <div class="bg-bg-inverse text-fg-inverse text-sm hidden md:block">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between">
      <div class="flex items-center gap-6">
        {business.phone && (
          <a
            href={`tel:${business.phone}`}
            class="flex items-center gap-2 text-fg-inverse/80 hover:text-fg-inverse transition-colors"
          >
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            {business.phone}
          </a>
        )}
        {business.email && (
          <a
            href={`mailto:${business.email}`}
            class="flex items-center gap-2 text-fg-inverse/80 hover:text-fg-inverse transition-colors"
          >
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,12 2,6" />
            </svg>
            {business.email}
          </a>
        )}
      </div>
      <div class="flex items-center gap-4">
        {business.social?.facebook && (
          <a href={business.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="text-fg-inverse/60 hover:text-fg-inverse transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </a>
        )}
        {business.social?.instagram && (
          <a href={business.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="text-fg-inverse/60 hover:text-fg-inverse transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-fg hover:text-primary transition-colors shrink-0">
        {business.businessName}
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center" aria-label="Main navigation">
        <ul class="flex items-center gap-1 list-none m-0 p-0">
          {navItems.map((item) => <NavItem node={item} />)}
        </ul>
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3">
        {business.phone && (
          <a
            href={`tel:${business.phone}`}
            class="text-sm font-semibold text-fg hover:text-primary transition-colors"
          >
            {business.phone}
          </a>
        )}
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-5 py-2.5 bg-primary text-fg-on-primary text-sm font-semibold rounded-lg hover:bg-primary-light transition-colors"
        >
          Get a Free Quote
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-bg-muted transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-nav-toggle
      >
        <span class="w-6 h-0.5 bg-fg transition-all duration-300" data-hamburger-line></span>
        <span class="w-6 h-0.5 bg-fg transition-all duration-300" data-hamburger-line></span>
        <span class="w-6 h-0.5 bg-fg transition-all duration-300" data-hamburger-line></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-border bg-bg"
    data-nav-menu
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-4">
      <ul class="flex flex-col gap-1 list-none m-0 p-0" id="mobile-nav-list">
        {navItems.map((item) => <NavItem node={item} />)}
      </ul>
      <div class="mt-6 pt-6 border-t border-border flex flex-col gap-3">
        {business.phone && (
          <a
            href={`tel:${business.phone}`}
            class="flex items-center justify-center gap-2 w-full px-5 py-2.5 border border-border rounded-lg text-sm font-semibold text-fg hover:bg-bg-muted transition-colors"
          >
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            {business.phone}
          </a>
        )}
        <a
          href="/contact"
          class="flex items-center justify-center w-full px-5 py-2.5 bg-primary text-fg-on-primary text-sm font-semibold rounded-lg hover:bg-primary-light transition-colors"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer to prevent content jumping under fixed header -->
<div class="h-16 lg:h-20" aria-hidden="true" id="header-spacer"></div>

<!-- Account for top bar height on md+ -->
<style>
  @media (min-width: 768px) {
    #header-spacer {
      height: calc(2.5rem + 4rem);
    }
  }
  @media (min-width: 1024px) {
    #header-spacer {
      height: calc(2.5rem + 5rem);
    }
  }
</style>