---
import { getBusinessData } from "@/lib/utils";
import NavItem from "@/components/layout/NavItem.astro";
import type { NavNode } from "@/lib/utils";

interface Props {
  navItems: NavNode[];
}

const { navItems } = Astro.props;
const business = await getBusinessData();
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      {business.businessName}
    </a>

    <nav class="nav">
      {navItems.map((item) => <NavItem node={item} />)}
    </nav>

    <div class="header-cta">
      <a href={`tel:${business.phone}`} class="phone">
        {business.phone}
      </a>
      <a href="/contact" class="btn-primary"> Get a Free Quote </a>
    </div>
  </div>
</header>
