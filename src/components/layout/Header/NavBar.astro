---
import "./navbar.less";
import NavItem from "@/components/layout/Header/NavItem.astro";
import { getBusinessData, getSiteData } from "@/lib/utils";
import type { NavNode } from "@/lib/utils";
import logo from "@/assets/images/logo.png";

interface Props {
  navItems: NavNode[];
}

const { navItems } = Astro.props;
const business = await getBusinessData();
const site = getSiteData();

// Get today's hours
import { getCollection } from "astro:content";
const hoursEntries = await getCollection("hoursSettings");
const hoursData = hoursEntries[0]?.data;
const days = [
  "Sunday",
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
];
const today = hoursData?.hours.find((h) => h.day === days[new Date().getDay()]);
const hoursDisplay = today?.closedAllDay
  ? "Closed Today"
  : today
    ? `${today.open} - ${today.close}`
    : null;
---

<header id="cs-navigation">
  <!-- Top Bar -->
  <div class="cs-top-bar">
    <div class="cs-top-container">
      <div class="cs-top-contact">
        {
          business.phone && (
            <a href={`tel:${business.phone}`} class="cs-top-link">
              <img
                class="cs-link-icon"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/phone-grey.svg"
                alt=""
                width="16"
                height="16"
                aria-hidden="true"
                decoding="async"
              />
              {business.phone}
            </a>
          )
        }
        {
          hoursDisplay && (
            <span class="cs-top-link">
              <img
                class="cs-link-icon"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/clock-grey.svg"
                alt=""
                width="20"
                height="20"
                aria-hidden="true"
                decoding="async"
              />
              Today: {hoursDisplay}
            </span>
          )
        }
      </div>
      <div class="cs-top-social">
        {
          business.social?.facebook && (
            <a
              href={business.social.facebook}
              class="cs-social-link"
              aria-label="Facebook"
              target="_blank"
              rel="noopener"
            >
              <img
                class="cs-social-icon"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/face-grey.svg"
                alt=""
                width="12"
                height="12"
                aria-hidden="true"
                decoding="async"
              />
            </a>
          )
        }
        {
          business.social?.instagram && (
            <a
              href={business.social.instagram}
              class="cs-social-link"
              aria-label="Instagram"
              target="_blank"
              rel="noopener"
            >
              <img
                class="cs-social-icon"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/insta-grey.svg"
                alt=""
                width="12"
                height="12"
                aria-hidden="true"
                decoding="async"
              />
            </a>
          )
        }
        {
          business.social?.youtube && (
            <a
              href={business.social.youtube}
              class="cs-social-link"
              aria-label="YouTube"
              target="_blank"
              rel="noopener"
            >
              <img
                class="cs-social-icon"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/youtube-grey.svg"
                alt=""
                width="12"
                height="12"
                aria-hidden="true"
                decoding="async"
              />
            </a>
          )
        }
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <div class="cs-container">
    <a
      href=""
      class="cs-logo"
      aria-label="Return to Peak Roofing Co. Home page"
    >
      <img
        src={logo.src}
        alt=""
        width={logo.width}
        aria-hidden="true"
        decoding="async"
      />
    </a>

    <nav class="cs-nav" aria-label="main navigation">
      <button
        class="cs-toggle"
        aria-label="mobile menu toggle"
        aria-expanded="false"
        aria-controls="cs-ul-wrapper"
        aria-haspopup="menu"
      >
        <span class="cs-box" aria-hidden="true">
          <span class="cs-line cs-line1"></span>
          <span class="cs-line cs-line2"></span>
          <span class="cs-line cs-line3"></span>
        </span>
      </button>

      <div class="cs-ul-wrapper" id="cs-ul-wrapper">
        <ul class="cs-ul">
          {navItems.map((item) => <NavItem node={item} />)}
        </ul>
      </div>
    </nav>

    <div class="cs-nav-actions">
      <a href={`tel:${business.phone}`} class="cs-button-solid cs-nav-button">
        {business.phone}
      </a>
      <!-- <button
        id="dark-mode-toggle"
        aria-label="dark mode toggle"
        aria-pressed="false"
      >
        <svg
          class="cs-moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 480 480"
          aria-hidden="true"
        >
          <path
            d="M459.782 347.328c-4.288-5.28-11.488-7.232-17.824-4.96-17.76 6.368-37.024 9.632-57.312 9.632-97.056 0-176-78.976-176-176 0-58.4 28.832-112.768 77.12-145.472 5.472-3.712 8.096-10.4 6.624-16.832S285.638 2.4 279.078 1.44C271.59.352 264.134 0 256.646 0c-132.352 0-240 107.648-240 240s107.648 240 240 240c84 0 160.416-42.688 204.352-114.176 3.552-5.792 3.04-13.184-1.216-18.496z"
          ></path>
        </svg>
        <img
          class="cs-sun"
          aria-hidden="true"
          src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons%2Fsun.svg"
          decoding="async"
          alt=""
          width="15"
          height="15"
        />
      </button> -->
    </div>
  </div>
</header>
