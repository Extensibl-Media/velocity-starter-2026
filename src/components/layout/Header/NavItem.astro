---
import type { NavNode } from "@/lib/utils";

interface Props {
  node: NavNode;
  depth?: number;
}

const { node, depth = 0 } = Astro.props;
const hasChildren = node.children && node.children.length > 0;
const dropdownId = `dropdown-${node.label.toLowerCase().replace(/\s+/g, '-')}-toggle`;
---

{depth === 0 && hasChildren ? (
  <!-- Top level dropdown -->
  <li class="cs-li cs-dropdown">
    {node.href ? (
      <a href={node.href} class="cs-li-link cs-dropdown-toggle">
        {node.label}
        <img
          class="cs-drop-icon"
          src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/chev-down.svg"
          alt=""
          width="15"
          height="15"
          decoding="async"
          aria-hidden="true"
        />
      </a>
    ) : (
      <button
        class="cs-li-link cs-dropdown-toggle"
        aria-haspopup="menu"
        aria-expanded="false"
        id={dropdownId}
      >
        {node.label}
        <img
          class="cs-drop-icon"
          src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/chev-down.svg"
          alt=""
          width="15"
          height="15"
          decoding="async"
          aria-hidden="true"
        />
      </button>
    )}
    <ul class="cs-drop-ul" aria-labelledby={dropdownId}>
      {node.children?.map((child) => (
        <Astro.self node={child} depth={1} />
      ))}
    </ul>
  </li>
) : depth === 1 && hasChildren ? (
  <!-- Second level with third level children -->
  <li class="cs-drop-li cs-drop3-main">
    {node.label}
    <img
      class="cs-drop-icon"
      src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/chev-down.svg"
      alt=""
      width="15"
      height="15"
      decoding="async"
      aria-hidden="true"
    />
    <ul class="cs-drop3">
      {node.children?.map((child) => (
        <Astro.self node={child} depth={2} />
      ))}
    </ul>
  </li>
) : depth === 1 ? (
  <!-- Second level plain link -->
  <li class="cs-drop-li">
    <a href={node.href} class="cs-li-link cs-drop-link">
      {node.label}
    </a>
  </li>
) : (
  <!-- Third level plain link -->
  <li class="cs-drop-li3">
    <a href={node.href} class="cs-li-link cs-drop-link">
      {node.label}
    </a>
  </li>
)}