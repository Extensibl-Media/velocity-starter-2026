---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer/Footer.astro";
import { getResolvedNav } from "@/lib/utils";
import NavBar from "@/components/layout/Header/NavBar.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    authors?: string[];
    tags?: string[];
  };
  noindex?: boolean;
  nofollow?: boolean;
  includeLocalBusinessSchema?: boolean;
  businessType?: string;
  openingHours?: string[];
  areaServed?: string[];
}

const {
  title,
  description,
  image,
  imageAlt,
  article,
  noindex = false,
  nofollow = false,
  includeLocalBusinessSchema = true,
  businessType = "GeneralContractor",
  openingHours,
  areaServed,
} = Astro.props;

const navItems = await getResolvedNav();
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  article={article}
  noindex={noindex}
  nofollow={nofollow}
  includeLocalBusinessSchema={includeLocalBusinessSchema}
  businessType={businessType}
  openingHours={openingHours}
  areaServed={areaServed}
>
  <!-- <Header slot="header" navItems={navItems} /> -->
  <NavBar slot="header" navItems={navItems} />
  <slot />
  <Footer slot="footer" />
</BaseLayout>
