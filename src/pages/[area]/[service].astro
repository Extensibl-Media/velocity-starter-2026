---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";
import {
  createBreadcrumbSchema,
  createLocalBusinessSchema,
} from "@/lib/schema";
import JsonLd from "@/components/seo/JsonLD.astro";
import { getBusinessData, getSiteData } from "@/lib/utils";
import { sectionRegistry } from "@/lib/sectionRegistry";

export async function getStaticPaths() {
  const localPages = await getCollection("localPages");
  return localPages
    .filter((page) => !page.data.draft)
    .map((page) => ({
      params: {
        area: page.data.area,
        service: page.data.service,
      },
      props: { page },
    }));
}

const { page } = Astro.props;

const business = await getBusinessData();
const site = getSiteData();

const allAreas = await getCollection("serviceAreas");
const area = allAreas.find((a) => a.data.slug === page.data.area);

const allServices = await getCollection("services");
const service = allServices.find((s) => s.data.slug === page.data.service);

const areaDisplay = area
  ? `${area.data.city}, ${area.data.state}`
  : page.data.area;

const breadcrumbs = createBreadcrumbSchema([
  { name: "Home", url: site.url },
  { name: areaDisplay, url: `${site.url}/${page.data.area}` },
  {
    name: page.data.title,
    url: `${site.url}/${page.data.area}/${page.data.service}`,
  },
]);

const localBusinessSchema = createLocalBusinessSchema(business, site, {
  businessType: "GeneralContractor",
  areaServed: [areaDisplay],
});
---

<MarketingLayout
  title={page.data.metaTitle}
  description={page.data.metaDescription}
  includeLocalBusinessSchema={false}
>
  <JsonLd schema={[breadcrumbs, localBusinessSchema]} />

  {
    page.data.sections.map((section) => {
      const Component = sectionRegistry[section.type];
      return <Component {...section} service={page.data.service} />;
    })
  }
</MarketingLayout>
