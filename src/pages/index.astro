---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageRenderer from '@/components/PageRenderer.astro';
import { getEntry } from 'astro:content';

const pageConfig = await getEntry('pages', 'home');
if (!pageConfig) return Astro.redirect('/404');
---

<MarketingLayout
  title={pageConfig.data.metaTitle}
  description={pageConfig.data.metaDescription}
>
  <PageRenderer config={pageConfig.data} />
</MarketingLayout>