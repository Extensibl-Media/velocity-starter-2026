---
import SecondaryPageHeader from "@/components/sections/Hero/SecondaryPageHeader.astro";
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import landingImage from "@assets/images/landing.jpg";
import { getImage } from "astro:assets";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<MarketingLayout>
  <SecondaryPageHeader title="About Us" image={optimizedImage} />
</MarketingLayout>
