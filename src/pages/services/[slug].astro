---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { getCollection, render } from "astro:content";
import { createBreadcrumbSchema, createFAQSchema } from "@/lib/schema";
import JsonLd from "@/components/seo/JsonLD.astro";
import { getBusinessData, getSiteData } from "@/lib/utils";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const business = await getBusinessData();
const site = getSiteData();

const allFaqs = await getCollection("faqs");
const serviceFaqs = allFaqs
  .filter((f) => !f.data.service || f.data.service === service.data.slug)
  .sort((a, b) => a.data.order - b.data.order);

const allReviews = await getCollection("reviews");
const serviceReviews = allReviews
  .filter((r) => r.data.featured)
  .filter((r) => !r.data.service || r.data.service === service.data.slug);

const breadcrumbs = createBreadcrumbSchema([
  { name: "Home", url: site.url },
  { name: "Services", url: `${site.url}/services` },
  {
    name: service.data.title,
    url: `${site.url}/services/${service.data.slug}`,
  },
]);

const faqSchema =
  serviceFaqs.length > 0
    ? createFAQSchema(
        serviceFaqs.map((f) => ({
          question: f.data.question,
          answer: f.data.answer,
        }))
      )
    : null;
---

<MarketingLayout
  title={service.data.metaTitle || service.data.title}
  description={service.data.metaDescription || service.data.description}
  image={service.data.image}
>
  <JsonLd schema={faqSchema ? [breadcrumbs, faqSchema] : [breadcrumbs]} />

  <article class="service-article">
    <header class="service-header">
      <h1>{service.data.title}</h1>
      <p>{service.data.description}</p>
      {
        service.data.isEmergency && (
          <div class="emergency-badge">⚡ 24/7 Emergency Service Available</div>
        )
      }
      <a href={`tel:${business.phone}`} class="btn-primary">
        Call Now: {business.phone}
      </a>
    </header>

    <div class="service-content">
      <Content />
    </div>

    {
      serviceReviews.length > 0 && (
        <section class="service-reviews">
          <h2>What Our Customers Say</h2>
          <ul>
            {serviceReviews.map((review) => (
              <li>
                <p>{review.data.body}</p>
                <cite>
                  — {review.data.author}
                  {review.data.location ? `, ${review.data.location}` : ""}
                </cite>
                <span>{"★".repeat(review.data.rating)}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      serviceFaqs.length > 0 && (
        <section class="service-faqs">
          <h2>Frequently Asked Questions</h2>
          {serviceFaqs.map((faq) => (
            <div class="faq-item">
              <h3>{faq.data.question}</h3>
              <p>{faq.data.answer}</p>
            </div>
          ))}
        </section>
      )
    }

    <section class="service-cta">
      <h2>Ready to Get Started?</h2>
      <a href={`tel:${business.phone}`} class="btn-primary">
        Call {business.phone}
      </a>
      <a href="/contact" class="btn-secondary"> Get a Free Quote </a>
    </section>
  </article>
</MarketingLayout>
