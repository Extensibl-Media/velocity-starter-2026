---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageRenderer from '@/components/PageRenderer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter(p => p.id !== 'home') // home handled separately
    .filter(p => !p.data.noindex)
    .map(p => ({
      params: { slug: p.id },
      props: { page: p },
    }));
}

const { page } = Astro.props;
---

<MarketingLayout
  title={page.data.metaTitle}
  description={page.data.metaDescription}
>
  <PageRenderer config={page.data} />
</MarketingLayout>