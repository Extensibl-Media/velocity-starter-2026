{
  "extends": "astro/tsconfigs/base",
  "include": [".astro/types.d.ts", "**/*", "./worker-configuration.d.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@assets/*": ["src/assets/*"],
      "@data/*": ["src/data/*"],
      "@content/*": ["src/content/*"],
      "@config/*": ["src/config/*"],
      "@styles/*": ["src/styles/*"],
      "@components/*": ["src/components/*"],
      "@js/*": ["src/js/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
